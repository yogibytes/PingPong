{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "esModuleInterop": true, 
    "module": "nodenext",
    "target": "es2024",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    
    
  }
}
